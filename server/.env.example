# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

PORT=3001

# String de conexão do PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:sua_senha@localhost:5432/smartnotes

# Chave secreta para assinar os tokens JWT
# Gere uma com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_secreta_muito_longa_e_aleatoria

# Tempo de expiração do token (ex: 7d, 30d, 24h)
JWT_EXPIRES_IN=7d
